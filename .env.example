# Copiez ce fichier en .env (jamais commité — voir .gitignore), éditez les valeurs
# reçues via le lien secret éphémère, puis chargez-les dans votre terminal : source .env

export VPC_ID="vpc-XXXXXXXX"               # VPC fourni pour le lab
export PRIVATE_SUBNET_1="subnet-AAAAAAAA"  # sous-réseau privé n°1 (AZ 1)
export PRIVATE_SUBNET_2="subnet-BBBBBBBB"  # sous-réseau privé n°2 (AZ 2)
export PUBLIC_SUBNET_1="subnet-CCCCCCCC"   # sous-réseau public n°1 (AZ 1) — uniquement si ALLOWED_CIDR est une IP publique
export PUBLIC_SUBNET_2="subnet-DDDDDDDD"   # sous-réseau public n°2 (AZ 2)
export USER_ID="1"                         # VOTRE numéro de participant (1, 2, 3...) ; 0 = animateur

# ALLOWED_CIDR : choisissez UNE des 3 options ci-dessous (laissez les deux autres en commentaire)
export ALLOWED_CIDR="10.10.0.0/16"             # Option 1 — CIDR du VPC partagé
# export ALLOWED_CIDR="$(curl -4 -s ip.me)/32"   # Option 2 — votre IP publique uniquement
# export ALLOWED_CIDR="<votre CIDR>"             # Option 3 — un CIDR de votre choix
